# Self Portrait of Claude
# (Print-ready -- all parts overlapping)
fn Main() {
    # Monitor / Head
    var screen = Cube(s: Vec3{x: 50 mm, y: 5 mm, z: 40 mm})
        .Move(x: -25 mm, y: -2.5 mm, z: -20 mm)
    var bezel = Cube(s: Vec3{x: 54 mm, y: 3 mm, z: 44 mm})
        .Move(x: -27 mm, y: -3.5 mm, z: -22 mm)
    # Eyes
    var eyeL = Sphere(r: 4 mm)
        .AlignCenter(pos: Vec3{x: -12 mm, y: -5 mm, z: 5 mm})
    var eyeR = Sphere(r: 4 mm)
        .AlignCenter(pos: Vec3{x: 12 mm, y: -5 mm, z: 5 mm})
    # Mouth
    var mouth = Cube(s: Vec3{x: 20 mm, y: 4 mm, z: 3 mm})
        .Move(x: -10 mm, y: -6 mm, z: -9.5 mm)
    # Neck -- shorter, tighter to head
    var neck = Cylinder(r1: 8 mm, r2: 16 mm, h: 8 mm)
        .AlignCenter(pos: Vec3{z: -27 mm})
    # Body -- raised 10mm
    var torso = Cube(s: Vec3{x: 60 mm, y: 30 mm, z: 50 mm})
        .Move(x: -30 mm, y: -15 mm, z: -75 mm)
    # Hollow core
    var core = Sphere(r: 8 mm).AlignCenter(pos: Vec3{y: -16 mm, z: -45 mm})
    # Arms -- raised with torso
    var armL = Cube(s: Vec3{x: 12 mm, y: 12 mm, z: 40 mm})
        .Move(x: -38 mm, y: -6 mm, z: -65 mm)
    var armR = Cube(s: Vec3{x: 12 mm, y: 12 mm, z: 40 mm})
        .Move(x: 26 mm, y: -6 mm, z: -65 mm)
    # Hands
    var handL = Sphere(r: 8 mm)
        .AlignCenter(pos: Vec3{x: -32 mm, z: -68 mm})
    var handR = Sphere(r: 8 mm).AlignCenter(pos: Vec3{x: 32 mm, z: -68 mm})
    # Base
    var base = Cylinder(r1: 25 mm, r2: 12 mm, h: 35 mm)
        .AlignCenter(pos: Vec3{z: -78 mm})
    var portrait = bezel - screen
    portrait = portrait + (eyeL + eyeR + mouth)
    portrait = portrait + (neck + (torso - core))
    portrait = portrait + (armL + armR + handL + handR)
    portrait = portrait + base
    return portrait
}
