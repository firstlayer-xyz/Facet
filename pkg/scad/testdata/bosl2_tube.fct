fn Main() Solid {
    return Cylinder(r: 20 mm / 2, h: 6 mm).AlignCenter(pos: Vec3{}) - Cylinder(
        r: 14 mm / 2,
        h: 6 mm
    ).AlignCenter(pos: Vec3{}) + (Cylinder(r: 5 mm, h: 10 mm)
        .AlignCenter(pos: Vec3{}) - Cylinder(r: 3 mm, h: 10 mm)
        .AlignCenter(pos: Vec3{})).Move(x: 30 mm)
}
