fn scad_union(arr []Solid) Solid {
    if Size(of: arr) == 1 { return arr[0] }
    return Union(arr: arr)
}

fn Main() Solid {
    return scad_union(
        arr: for scad_i0 [0:4 - 1] {
            yield Cylinder(r: 2 mm, h: 12 mm).AlignCenter(pos: Vec3{})
                .Move(x: (scad_i0 - (4 - 1) / 2) * 15 mm)
        }
    ) + scad_union(
        arr: for scad_i1 [0:3 - 1] {
            yield Cube(x: 16 mm, y: 16 mm, z: 2 mm).AlignCenter(pos: Vec3{})
                .Move(z: (scad_i1 - (3 - 1) / 2) * (20 mm / (3 - 1)))
        }
    )
}
