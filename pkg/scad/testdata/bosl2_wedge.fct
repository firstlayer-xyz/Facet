fn Main() Solid {
    return Mesh{vertices: []Vec3[
            {x: 20 mm / 2, y: 12 mm / 2, z: -(8 mm / 2)},
            {x: 20 mm / 2, y: -(12 mm / 2), z: -(8 mm / 2)},
            {x: 20 mm / 2, y: -(12 mm / 2), z: 8 mm / 2},
            {x: -(20 mm / 2), y: 12 mm / 2, z: -(8 mm / 2)},
            {x: -(20 mm / 2), y: -(12 mm / 2), z: -(8 mm / 2)},
            {x: -(20 mm / 2), y: -(12 mm / 2), z: 8 mm / 2}
        ],
        indices: []Face[
            {v0: 0, v1: 2, v2: 1}, {v0: 3, v1: 4, v2: 5}, {v0: 0, v1: 1, v2: 3},
            {v0: 1, v1: 4, v2: 3}, {v0: 1, v1: 2, v2: 4}, {v0: 2, v1: 5, v2: 4},
            {v0: 2, v1: 3, v2: 5}, {v0: 0, v1: 3, v2: 2}
        ]}.Solid().Move(x: 20 mm / 2, y: 12 mm / 2, z: 8 mm / 2) + Mesh{vertices: []Vec3[
            {x: 16 mm / 2, y: 16 mm / 2, z: -(10 mm / 2)},
            {x: 16 mm / 2, y: -(16 mm / 2), z: -(10 mm / 2)},
            {x: 16 mm / 2, y: -(16 mm / 2), z: 10 mm / 2},
            {x: -(16 mm / 2), y: 16 mm / 2, z: -(10 mm / 2)},
            {x: -(16 mm / 2), y: -(16 mm / 2), z: -(10 mm / 2)},
            {x: -(16 mm / 2), y: -(16 mm / 2), z: 10 mm / 2}
        ],
        indices: []Face[
            {v0: 0, v1: 2, v2: 1}, {v0: 3, v1: 4, v2: 5}, {v0: 0, v1: 1, v2: 3},
            {v0: 1, v1: 4, v2: 3}, {v0: 1, v1: 2, v2: 4}, {v0: 2, v1: 5, v2: 4},
            {v0: 2, v1: 3, v2: 5}, {v0: 0, v1: 3, v2: 2}
        ]}.Solid().Move(x: 40 mm)
}
